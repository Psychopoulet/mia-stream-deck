{

  "name": "mia-stream-deck",
  "version": "1.0.0",
  "description": "Stream deck plugin for MIA.",

  "type": "commonjs",
  "typings": "./lib/cjs/main.d.cts",
  "main": "./lib/cjs/main.cjs",

  "exports": {
    ".": {
      "require": {
        "types": "./lib/cjs/main.d.cts",
        "default": "./lib/cjs/main.cjs"
      }
    }
  },

  "scripts": {

    "transpile-openapi-back": "npx openapi-typescript ./lib/data/Descriptor.json -o ./lib/src/Descriptor.ts",
    "transpile-openapi-front": "npx openapi-typescript ./lib/data/Descriptor.json -o ./public/src/Descriptor.ts",
    "transpile-openapi": "npm run transpile-openapi-back && npm run transpile-openapi-front",

    "lint-back": "npm run transpile-openapi-back && npx eslint --config .eslintrc-back.js --ext .ts,.cts,.mts ./lib/src/**/*",
    "lint-front": "npm run transpile-openapi-front && npx eslint --config .eslintrc-front.js --ext .tsx,.ts ./public/src/**/*",
    "lint-tests": "npx eslint --config .eslintrc-tests.js --ext .js ./test/**/*",
    "lint": "npm run lint-back && npm run lint-front && npm run lint-tests",

    "clean-back": "npx rimraf ./lib/cjs",
    "clean-front": "npx rimraf ./public/dist",
    "clean": "npm run clean-back && npm run clean-front",

    "build-back": "npm run clean-back && npm run transpile-openapi-back && npx tsc --project ./tsconfig.json",
    "build-front": "npm run clean-front && npm run transpile-openapi-front && npx webpack --config ./webpack.config.js",
    "build": "npm run build-back && npm run build-front",

    "check-node-engine": "npx check-node-engine",
    "check-requires": "npx used-deps-analyzer ./package.json ./lib/src --no-dev",
    "check-updates": "npx check-version-modules --no-fail-at-major --fail-at-minor --fail-at-patch",
    "unit-tests": "npx mocha",
    "unit-tests-local": "npx nyc --reporter=html --reporter=text mocha",

    "tests": "npm run lint && npm run check-node-engine && npm run check-requires && npm run check-updates && npm run build && npm run unit-tests-local"

  },

  "files": [
    "lib/cjs",
    "lib/data",
    "public/dist",
    "public/pictures",
    "public/index.html"
  ],
  "engines": {
    "node": ">=22.22.3"
  },

  "dependencies": {
    "node-pluginsmanager-plugin": "7.3.0",
    "@hurdlegroup/robotjs": "0.12.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/socket.io": "3.0.2",
    "@types/ws": "8.18.1",
    "check-node-engine": "1.1.0",
    "check-version-modules": "2.5.0",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "husky": "9.1.7",
    "mocha": "11.7.6",
    "node-containerpattern": "1.12.0",
    "node-pluginsmanager": "3.3.0",
    "nyc": "18.0.0",
    "openapi-typescript": "7.13.0",
    "react": "19.2.6",
    "react-bootstrap-fontawesome": "git+ssh://git@github.com/Psychopoulet/react-bootstrap-fontawesome",
    "react-dom": "19.2.6",
    "rimraf": "6.1.3",
    "terser-webpack-plugin": "5.6.1",
    "ts-loader": "9.6.0",
    "typescript": "5.9.3",
    "used-deps-analyzer": "0.4.0",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  },

  "author": "Sébastien VIDAL",
  "contributors": [],
  "license": "ISC",

  "homepage": "https://github.com/Psychopoulet/mia-stream-deck#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/mia-stream-deck.git"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/mia-stream-deck/issues"
  }

}

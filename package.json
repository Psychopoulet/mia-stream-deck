{
  "name": "mia-stream-deck",
  "version": "1.0.0",
  "description": "Stream deck plugin for MIA",
  "typings": "./lib/cjs/main.d.cts",
  "main": "./lib/cjs/main.cjs",
  "scripts": {

    "prepare": "npx husky",

    "lint": "npx eslint --config \".eslintrc-src.js\" --ext .cts,.ts \"./lib/src/**/*\" && npx eslint --config \".eslintrc-tests.js\" \"./bin/*.js\" \"./test/**/*.js\"",
    "check-requires": "npx used-deps-analyzer \"./package.json\" \"./lib/src\" --no-dev --overkill \"fs-extra\" \"node-promfs\"",
    "check-updates": "npx check-version-modules",
    "unit-tests": "npm run-script build && npx nyc --reporter=html --reporter=text mocha",
    "tests": "npm run-script lint && npm run-script check-requires && npm run-script check-updates && npm run-script unit-tests",

    "transpile-openapi": "npx openapi-typescript ./lib/data/Descriptor.json -o ./lib/src/Descriptor.ts ",

    "clean-api": "npx rimraf \"./lib/cjs\"",
    "build-api": "npm run-script clean-api && npm run-script transpile-openapi && npx tsc --project \"./tsconfig.json\"",

    "clean-front": "npx rimraf \"./public/dist/bundle.js",
    "build-front": "npm run-script clean-front && npm run-script transpile-openapi && npx webpack --config \"./webpack.config.js\"",

    "ci": "npm run-script tests && npx nyc report --reporter=text-lcov | coveralls"

  },
  "files": [
    "/bin",
    "/lib/cjs",
    "/lib/data",
    "/public/dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "node-pluginsmanager-plugin": "6.4.5"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "24.3.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@types/socket.io": "3.0.2",
    "@types/ws": "8.18.1",
    "check-version-modules": "2.1.3",
    "coveralls": "3.1.1",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "husky": "9.1.7",
    "mocha": "11.7.2",
    "node-confmanager": "1.9.0",
    "node-containerpattern": "1.8.0",
    "nyc": "17.1.0",
    "openapi-typescript": "7.9.1",
    "react": "19.1.1",
    "react-bootstrap-fontawesome": "git+ssh://git@github.com/Psychopoulet/react-bootstrap-fontawesome",
    "react-dom": "19.1.1",
    "rimraf": "6.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.9.2",
    "used-deps-analyzer": "0.1.8",
    "webpack": "5.101.3",
    "webpack-cli": "6.0.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run-script lint",
      "pre-push": "npm run-script unit-tests",
      "pre-receive": "npm run-script tests"
    }
  },
  "author": "Sébastien VIDAL",
  "contributors": [],
  "license": "ISC",
  "homepage": "https://github.com/Psychopoulet/MIA-stream-deck#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/MIA-stream-deck"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/MIA-stream-deck/issues"
  }
}

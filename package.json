{

  "name": "mia-stream-deck",
  "version": "1.0.0",
  "description": "Stream deck plugin for MIA.",

  "type": "commonjs",
  "typings": "./lib/cjs/main.d.cts",
  "main": "./lib/cjs/main.cjs",

  "exports": {
    ".": {
      "require": {
        "types": "./lib/cjs/main.d.cts",
        "default": "./lib/cjs/main.cjs"
      }
    }
  },

  "scripts": {

    "prepare": "npx husky || true",

    "lint-back": "npx eslint --config .eslintrc-back.js --ext .ts,.cts,.mts ./lib/src/**/*",
    "lint-front": "npx eslint --config .eslintrc-front.js --ext .tsx,.ts ./public/src/**/*",
    "lint-tests": "npx eslint --config .eslintrc-tests.js --ext .js,.cjs,.mjs ./test/**/*",
    "lint": "npm run lint-back && npm run lint-front && npm run lint-tests",

    "clean-back": "npx rimraf ./lib/cjs",
    "clean-front": "npx rimraf ./public/cjs",
    "clean": "npm run clean-back && npm run clean-front",

    "transpile-openapi": "npx openapi-typescript ./lib/data/Descriptor.json -o ./lib/src/Descriptor.ts ",

    "build-back": "npm run clean-back && npm run transpile-openapi && npx tsc --project ./tsconfig.json",
    "build-front": "npm run clean-front && npm run transpile-openapi && npx webpack --config \"./webpack.config.js\"",
    "build": "npm run build-back && npm run build-front",

    "check-requires": "npx used-deps-analyzer \"./package.json\" \"./lib/src\" --no-dev --overkill \"fs-extra\" \"node-promfs\"",
    "check-updates": "npx check-version-modules --no-fail-at-major --fail-at-minor --fail-at-patch",
    "unit-tests": "echo 'not unit tests here'",
    "unit-tests-local": "echo 'not unit tests here'",

    "tests": "npm run lint && npm run check-requires && npm run check-updates && npm run unit-tests"

  },

  "files": [
    "lib/cjs",
    "lib/data",
    "public/dist"
  ],
  "engines": {
    "node": ">=22.22.0"
  },

  "dependencies": {
    "node-pluginsmanager-plugin": "7.1.0",
    "@hurdlegroup/robotjs": "0.12.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/socket.io": "3.0.2",
    "@types/ws": "8.18.1",
    "check-version-modules": "2.3.0",
    "eslint-plugin-personnallinter": "git+ssh://git@github.com/Psychopoulet/eslint-plugin-personnallinter",
    "husky": "9.1.7",
    "node-containerpattern": "1.10.0",
    "node-pluginsmanager": "3.2.0",
    "openapi-typescript": "7.13.0",
    "react": "19.2.5",
    "react-bootstrap-fontawesome": "git+ssh://git@github.com/Psychopoulet/react-bootstrap-fontawesome",
    "react-dom": "19.2.5",
    "rimraf": "6.1.3",
    "terser-webpack-plugin": "5.4.0",
    "ts-loader": "9.5.7",
    "typescript": "5.9.3",
    "used-deps-analyzer": "0.3.0",
    "webpack": "5.106.1",
    "webpack-cli": "7.0.2"
  },

  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "pre-push": "npm run build && npm run unit-tests-local"
    }
  },
  "author": "Sébastien VIDAL",
  "contributors": [],
  "license": "ISC",

  "homepage": "https://github.com/Psychopoulet/mia-stream-deck#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/Psychopoulet/mia-stream-deck.git"
  },
  "bugs": {
    "url": "https://github.com/Psychopoulet/mia-stream-deck/issues"
  }

}

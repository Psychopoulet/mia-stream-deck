{
	"openapi": "3.0.2",
	"info": {
		"title": "mia-stream-deck",
		"version": "1.0.0"
	},
	"paths": {

		"/mia-stream-deck/descriptor": {
			"get": {
				"description": "",
				"summary": "Plugin's descriptor",
				"operationId": "getDescriptor",
				"responses": {
					"200": {
						"description": "Plugin's descriptor",
						"content": {
							"application/json": {
								"schema": {
									"type": "object"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/status": {
			"get": {
				"description": "",
				"summary": "Plugin's status",
				"operationId": "getStatus",
				"responses": {
					"200": {
						"description": "Plugin's status",
						"content": {
							"application/json": {
								"schema": {
									"type": "string",
									"enum": [ "ENABLED", "INITIALIZED" ]
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},

		"/mia-stream-deck/public/index.html": {
			"get": {
				"description": "",
				"summary": "Plugin's front",
				"operationId": "getFrontIndex",
				"responses": {
					"200": {
						"description": "Plugin's front",
						"content": {
							"text/html": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/public/bundle.js": {
			"get": {
				"description": "",
				"summary": "Plugin's front",
				"operationId": "getFrontApp",
				"responses": {
					"200": {
						"description": "Plugin's front app",
						"content": {
							"application/javascript": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},

		"/mia-stream-deck/api/swipe/{direction}": {
			"put": {
				"description": "",
				"summary": "Swipe in a specific direction",
				"operationId": "swipe",
				"parameters": [
					{
						"name": "direction",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"enum": [
								"top", "right", "down", "left"
							]
						}
					}
				],
				"responses": {
					"201": {
						"description": "Everything is fine",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/table": {
			"get": {
				"description": "",
				"summary": "Get the command table",
				"operationId": "getTable",
				"responses": {
					"200": {
						"description": "Table registered",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/Line"
									}
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		}

	},
	"components": {
		"schemas": {
			"Error": {
				"type": "object",
				"properties": {
					"code": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				},
				"required": [ "code", "message" ]
			},
			"Line": {
				"type": "array",
				"items": {
					"$ref": "#/components/schemas/Row"
				}
			},
			"Row": {
				"type": "object",
				"properties": {
					"icon": {
						"type": "string"
					},
					"picture": {
						"type": "string"
					},
					"action": {
						"type": "object",
						"properties": {
							"type": {
								"type": "string",
								"enum": [ "empty", "command", "input-string", "input-key" ]
							}
						},
						"required": [ "type" ]
					}
				},
				"required": [ "action" ]
			}
		}
	},
	"servers": [
		{
			"url": "http://localhost:8000/",
			"description": "test server"
		}
	]
}

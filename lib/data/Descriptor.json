{
	"openapi": "3.0.2",
	"info": {
		"title": "mia-stream-deck",
		"version": "1.3.0",
		"description": "Stream deck plugin for MIA."
	},
	"paths": {
		"/mia-stream-deck/api/descriptor": {
			"get": {
				"description": "",
				"summary": "Plugin's descriptor",
				"operationId": "getPluginDescriptor",
				"responses": {
					"200": {
						"description": "Plugin's descriptor",
						"content": {
							"application/json": {
								"schema": {
									"type": "object"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/status": {
			"get": {
				"description": "",
				"summary": "Plugin's status",
				"operationId": "getPluginStatus",
				"responses": {
					"200": {
						"description": "Plugin's status",
						"content": {
							"application/json": {
								"schema": {
									"type": "string",
									"enum": [ "ENABLED", "INITIALIZED", "RELEASED" ]
								}
							}
						}
					},
					"404": {
						"description": "The plugin is not enabled (=RELEASED)",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},

		"/mia-stream-deck/public/index.html": {
			"get": {
				"description": "",
				"summary": "Plugin's front",
				"operationId": "getFrontIndex",
				"responses": {
					"200": {
						"description": "Plugin's front",
						"content": {
							"text/html": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/public/table.html": {
			"get": {
				"description": "",
				"summary": "Plugin's front for fullscreen table",
				"operationId": "getTablePage",
				"parameters": [
					{
						"name": "tablename",
						"in": "query",
						"required": true,
						"schema": { "$ref": "#/components/schemas/TableName" }
					}
				],
				"responses": {
					"200": {
						"description": "Plugin's front for fullscreen table",
						"content": {
							"text/html": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/public/bundle.min.js": {
			"get": {
				"description": "",
				"summary": "Plugin's front app",
				"operationId": "getFrontApp",
				"responses": {
					"200": {
						"description": "Plugin's front app",
						"content": {
							"application/javascript": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/public/bundle.min.js.map": {
			"get": {
				"description": "",
				"summary": "Plugin's front app map",
				"operationId": "getFrontAppMap",
				"responses": {
					"200": {
						"description": "Plugin's front app",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"additionalProperties": true
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/tables": {
			"get": {
				"description": "",
				"summary": "Get the tables' names",
				"operationId": "getTables",
				"responses": {
					"200": {
						"description": "Tables registered",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"description": "Commands table names",
									"uniqueItems": true,
									"items": {
										"$ref": "#/components/schemas/TableName"
									}
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/tables/{tablename}": {
			"get": {
				"description": "",
				"summary": "Get the command table",
				"operationId": "getTableByName",
				"parameters": [
					{
						"name": "tablename",
						"in": "path",
						"required": true,
						"schema": {
							"$ref": "#/components/schemas/TableName"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Table registered",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Table"
								}
							}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			},
			"put": {
				"description": "",
				"summary": "Add new commands table",
				"operationId": "addTable",
				"parameters": [
					{
						"name": "tablename",
						"in": "path",
						"required": true,
						"schema": {
							"$ref": "#/components/schemas/TableName"
						}
					}
				],
				"responses": {
					"201": {
						"description": "New table added",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			},
			"post": {
				"description": "",
				"summary": "Update the commands table",
				"operationId": "updateTable",
				"parameters": [
					{
						"name": "tablename",
						"in": "path",
						"required": true,
						"schema": {
							"$ref": "#/components/schemas/TableName"
						}
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/Table"
							}
						}
					}
				},
				"responses": {
					"204": {
						"description": "Table updated",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			},
			"delete": {
				"description": "",
				"summary": "Delete the commands table",
				"operationId": "deleteTableByName",
				"parameters": [
					{
						"name": "tablename",
						"in": "path",
						"required": true,
						"schema": {
							"$ref": "#/components/schemas/TableName"
						}
					}
				],
				"responses": {
					"204": {
						"description": "Table deleted",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/execute-command": {
			"put": {
				"description": "",
				"summary": "Execute the command",
				"operationId": "executeCommand",
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/Command"
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Command running",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occurred",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"PluginName": {
				"type": "string",
				"enum": [ "mia-stream-deck" ]
			},
			"Error": {
				"type": "object",
				"description": "JSON Error description",
				"properties": {
					"code": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				},
				"required": [ "code", "message" ]
			},
			"TableName": {
				"type": "string",
				"minLength": 1
			},
			"Table": {
				"type": "array",
				"description": "Commands table description, contains an array for the lines which contains an array for the rows. Each row is a command.",
				"items": {
					"type": "array",
					"items": {
						"$ref": "#/components/schemas/Command"
					}
				}
			},
			"Command": {
				"type": "object",
				"description": "Differents command types descriptions",
				"properties": {
					"icon": {
						"type": "string",
						"minLength": 1
					},
					"picture": {
						"type": "string",
						"minLength": 1
					},
					"label": {
						"type": "string",
						"minLength": 1
					},
					"action": {
						"oneOf": [
							{ "$ref": "#/components/schemas/ActionEmpty" },
							{ "$ref": "#/components/schemas/ActionInputString" },
							{ "$ref": "#/components/schemas/ActionInputKey" },
							{ "$ref": "#/components/schemas/ActionPlugin" }
						]
					}
				},
				"required": [ "action" ]
			},
			"ActionEmpty": {
				"type": "object",
				"description": "Empty command (an empty row in the table)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "EMPTY" ]
					}
				},
				"required": [ "type" ]
			},
			"ActionInputString": {
				"type": "object",
				"description": "Input string (keyboard simulator)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "INPUT-STRING" ]
					},
					"string": {
						"type": "string",
						"minLength": 1
					},
					"enter": {
						"description": "Add a 'enter' input at the end of the string (default : false)",
						"type": "boolean"
					}
				},
				"required": [ "type", "string" ]
			},
			"ActionInputKey": {
				"type": "object",
				"description": "Input specific key (keyboard simulator)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "INPUT-KEY" ]
					},
					"key": {
						"anyOf": [
							{
								"type": "string",
								"description": "global key, like a single letter",
								"minLength": 1,
								"maxLength": 1
							},
							{
								"type": "string",
								"description": "specific key, like \"backspace\"",
								"enum": [
									"f1", "f2", "f3", "f4", "f5", "f6", "f7", "f8", "f9", "f10", "f11", "f12",
									"f13", "f14", "f15", "f16", "f17", "f18", "f19", "f20", "f21", "f22", "f23", "f24",
									"insert", "home", "pageup", "delete", "end", "pagedown", "scroll_lock",
									"command", "menu", "alt", "right_alt", "control", "left_control", "right_control", "shift", "right_shift",
									"space", "backspace", "enter", "escape", "tab", "up", "down", "left", "right", "printscreen", "capslock",
									"numpad_lock", "numpad_0", "numpad_1", "numpad_2", "numpad_3", "numpad_4", "numpad_5", "numpad_6",
									"numpad_7", "numpad_8", "numpad_9", "numpad_+", "numpad_-", "numpad_*", "numpad_/", "numpad_.",
									"audio_mute", "audio_vol_up", "audio_vol_down", "audio_play", "audio_stop", "audio_pause", "audio_prev",
									"audio_next", "audio_rewind", "audio_forward", "audio_repeat", "audio_random",
									"lights_mon_up", "lights_mon_down", "lights_kbd_toggle", "lights_kbd_up", "lights_kbd_down"
								]
							}
						]
					},
					"alt": {
						"description": "Key + alt (default : false)",
						"type": "boolean"
					},
					"ctrl": {
						"description": "Key + ctrl (default : false)",
						"type": "boolean"
					},
					"shift": {
						"description": "Key + shift (default : false)",
						"type": "boolean"
					},
					"command": {
						"description": "Key + command (default : false) (mac only)",
						"type": "boolean"
					}
				},
				"required": [ "type", "key" ]
			},
			"ActionPlugin": {
				"type": "object",
				"description": "Execute a plugin method",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "PLUGIN" ]
					},
					"plugin": {
						"type": "string",
						"minLength": 1
					},
					"operationId": {
						"type": "string",
						"minLength": 1
					},
					"urlParameters": {
						"type": "object",
						"properties": {
							"path": {
								"type": "object",
								"additionalProperties": {
									"type": "string",
									"minLength": 1
								}
							},
							"query": {
								"type": "object",
								"additionalProperties": {
									"type": "string",
									"minLength": 1
								}
							},
							"headers": {
								"type": "object",
								"additionalProperties": {
									"type": "string",
									"minLength": 1
								}
							},
							"cookies": {
								"type": "object",
								"additionalProperties": {
									"type": "string",
									"minLength": 1
								}
							}
						}
					},
					"bodyParameters": {
						"description": "Can be any value"
					}
				},
				"required": [ "type", "plugin", "operationId" ]
			},
			"PushEventPluginInitialized": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventPluginInitialized"
			},
			"PushEventPluginReleased": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventPluginReleased"
			},
			"PushEventPluginError": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventPluginError"
			},
			"PushEventTableAdded": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventTableAdded"
			},
			"PushEventTableDeleted": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventTableDeleted"
			},
			"PushEventCommandRunning": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventCommandRunning"
			},
			"PushEventCommandSuccess": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventCommandSuccess"
			},
			"PushEventCommandFail": {
				"$ref": "./DescriptorEvents.json#/components/schemas/PushEventCommandFail"
			}
		}
	},
	"servers": [
		{
			"url": "http://localhost:8000/",
			"description": "test server"
		}
	]
}

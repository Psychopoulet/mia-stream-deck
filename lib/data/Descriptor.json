{
	"openapi": "3.0.2",
	"info": {
		"title": "mia-stream-deck",
		"version": "1.0.0"
	},
	"paths": {

		"/mia-stream-deck/descriptor": {
			"get": {
				"description": "",
				"summary": "Plugin's descriptor",
				"operationId": "getDescriptor",
				"responses": {
					"200": {
						"description": "Plugin's descriptor",
						"content": {
							"application/json": {
								"schema": {
									"type": "object"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/status": {
			"get": {
				"description": "",
				"summary": "Plugin's status",
				"operationId": "getStatus",
				"responses": {
					"200": {
						"description": "Plugin's status",
						"content": {
							"application/json": {
								"schema": {
									"type": "string",
									"enum": [ "ENABLED", "INITIALIZED" ]
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},

		"/mia-stream-deck/public/index.html": {
			"get": {
				"description": "",
				"summary": "Plugin's front",
				"operationId": "getFrontIndex",
				"responses": {
					"200": {
						"description": "Plugin's front",
						"content": {
							"text/html": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/public/bundle.js": {
			"get": {
				"description": "",
				"summary": "Plugin's front",
				"operationId": "getFrontApp",
				"responses": {
					"200": {
						"description": "Plugin's front app",
						"content": {
							"application/javascript": {
								"schema": {
									"type": "string"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},

		"/mia-stream-deck/api/swipe/{direction}": {
			"put": {
				"description": "",
				"summary": "Swipe in a specific direction",
				"operationId": "swipe",
				"parameters": [
					{
						"name": "direction",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"enum": [
								"top", "right", "down", "left"
							]
						}
					}
				],
				"responses": {
					"201": {
						"description": "Everything is fine",
						"content": {
							"application/json": {}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		},
		"/mia-stream-deck/api/table": {
			"get": {
				"description": "",
				"summary": "Get the command table",
				"operationId": "getTable",
				"responses": {
					"200": {
						"description": "Table registered",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Table"
								}
							}
						}
					},
					"default": {
						"description": "An error occured",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Error"
								}
							}
						}
					}
				}
			}
		}

	},
	"components": {
		"schemas": {
			"Error": {
				"type": "object",
				"description": "JSON Error description",
				"properties": {
					"code": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				},
				"required": [ "code", "message" ]
			},
			"Table": {
				"type": "array",
				"description": "Commands table description, contains an array for the lines which contains an array for the rows. Each row is a command.",
				"items": {
					"type": "array",
					"items": {
						"$ref": "#/components/schemas/Command"
					}
				}
			},
			"Command": {
				"type": "object",
				"description": "Differents command types descriptions",
				"properties": {
					"icon": {
						"type": "string"
					},
					"picture": {
						"type": "string",
						"format": "uri"
					},
					"action": {
						"oneOf": [
							{ "$ref": "#/components/schemas/ActionEmpty" },
							{ "$ref": "#/components/schemas/ActionInputString" },
							{ "$ref": "#/components/schemas/ActionInputKey" },
							{ "$ref": "#/components/schemas/ActionCommand" },
							{ "$ref": "#/components/schemas/ActionPlugin" }
						]
					}
				},
				"required": [ "action" ]
			},
			"ActionEmpty": {
				"type": "object",
				"description": "Empty command (an empty row in the table)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "empty" ]
					}
				},
				"required": [ "type" ]
			},
			"ActionInputString": {
				"type": "object",
				"description": "Input string (keyboard simulator)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "input-string" ]
					},
					"string": {
						"type": "string",
						"minLength": 1
					},
					"enter": {
						"description": "Add a 'enter' input at the end of the string (default : false)",
						"type": "boolean"
					}
				},
				"required": [ "type", "string" ]
			},
			"ActionInputKey": {
				"type": "object",
				"description": "Input specific key (keyboard simulator)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "input-key" ]
					},
					"key": {
						"type": "string",
						"minLength": 1
					},
					"alt": {
						"description": "Key + alt (default : false)",
						"type": "boolean"
					},
					"ctrl": {
						"description": "Key + ctrl (default : false)",
						"type": "boolean"
					},
					"shift": {
						"description": "Key + shift (default : false)",
						"type": "boolean"
					}
				},
				"required": [ "type", "key" ]
			},
			"ActionCommand": {
				"type": "object",
				"description": "Execute a command line (like in a terminal)",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "command" ]
					},
					"command": {
						"type": "string",
						"minLength": 1
					}
				},
				"required": [ "type", "command" ]
			},
			"ActionPlugin": {
				"type": "object",
				"description": "Execute a plugin method",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "plugin" ]
					},
					"plugin": {
						"type": "string",
						"minLength": 1
					},
					"operationId": {
						"type": "string",
						"minLength": 1
					}
				},
				"required": [ "type", "plugin", "operationId" ]
			}
		}
	},
	"servers": [
		{
			"url": "http://localhost:8000/",
			"description": "test server"
		}
	]
}
